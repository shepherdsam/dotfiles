# Ghostty configuration
# Ported from Alacritty + managed by bin/theme for light/dark switching

# Font
font-family = "JetBrainsMono Nerd Font Mono"
font-size = 14

# Window appearance
# window-padding-x = 4
# window-padding-y = 4
window-padding-balance = true
background-opacity = 0.95
# background-blur = true

# macOS specific
macos-titlebar-style = hidden

# Theme (managed by bin/theme script - do not edit directly)
theme = one_dark
