#!/usr/bin/env zsh
# bin/theme - Light / Dark / Auto theme switcher for Ghostty + Alacritty + Tmux + Neovim
# Part of https://github.com/samshepherd/dev-dotfiles
#
# Usage:
#   theme              # status
#   theme dark         # force dark (one_dark)
#   theme light        # force light (one_light)
#   theme auto         # follow macOS appearance (defaults read -g AppleInterfaceStyle)
#   theme toggle       # flip current
#   theme status       # show what each app is using
#   theme -h | --help

set -euo pipefail

# --- Config paths (always target the live ~/.config versions) ---
ALAC="$HOME/.config/alacritty/alacritty.toml"
GHOSTTYC="$HOME/.config/ghostty/config"
TMUXC="$HOME/.config/tmux/tmux.conf"
NVIMC="$HOME/.config/nvim/lua/chadrc.lua"

# --- Colors (zsh) ---
autoload -U colors && colors
GREEN="%F{green}"
YELLOW="%F{yellow}"
RED="%F{red}"
CYAN="%F{cyan}"
RESET="%f"

printc() { print -P -- "$1${RESET}"; }

usage() {
  print -P -- "${CYAN}theme${RESET} - switch terminal color scheme (light/dark) across Ghostty, Alacritty, Tmux, Neovim"
  print -P -- ""
  print -P -- "Usage:"
  print -P -- "  ${CYAN}theme${RESET}              Show current status for all apps"
  print -P -- "  ${CYAN}theme dark${RESET}         Switch to dark (one_dark + onedark)"
  print -P -- "  ${CYAN}theme light${RESET}        Switch to light (one_light + one_light)"
  print -P -- "  ${CYAN}theme auto${RESET}         Follow macOS system appearance"
  print -P -- "  ${CYAN}theme toggle${RESET}       Flip between dark and light"
  print -P -- "  ${CYAN}theme status${RESET}       Same as running with no arguments"
  print -P -- "  ${CYAN}theme -h, --help${RESET}   This help"
  print -P -- ""
  print -P -- "After changing:"
  print -P -- "  ${CYAN}Ghostty:${RESET}   press ${CYAN}super+shift+,${RESET} (or Command Palette → Reload Config)"
  print -P -- "  ${CYAN}Alacritty:${RESET} auto-reloads on config change"
  print -P -- "Tmux is sourced by the script. Neovim picks up the new chadrc on restart"
  print -P -- "or via ${CYAN}:lua require('base46').toggle_theme()${RESET} (the theme_toggle pair is kept in sync)."
}

# --- Detect current theme by inspecting Ghostty (primary source of truth) ---
# Alacritty is kept in sync by apply(), but Ghostty is used for current()/toggle/auto decisions.
current() {
  if [[ ! -f "$GHOSTTYC" ]]; then
    echo "unknown"
    return
  fi
  # Look for the active theme = line managed by this script
  if grep -v '^#' "$GHOSTTYC" | grep -q '^theme = one_dark'; then
    echo "dark"
  elif grep -v '^#' "$GHOSTTYC" | grep -q '^theme = one_light'; then
    echo "light"
  else
    echo "unknown"
  fi
}

# --- macOS appearance ---
detect_appearance() {
  local style
  style=$(defaults read -g AppleInterfaceStyle 2>/dev/null || echo "Light")
  if [[ "$style" == "Dark" ]]; then
    echo "dark"
  else
    echo "light"
  fi
}

# --- Apply the sed edits for a given mode (updates both terminals + tmux + nvim) ---
apply() {
  local mode="$1"   # dark or light

  if [[ "$mode" == "dark" ]]; then
    # Ghostty
    sed -i '' 's/^theme = one_.*$/theme = one_dark/' "$GHOSTTYC"
    # Alacritty (kept for users who still run it)
    sed -i '' 's|  "./themes/one_.*.toml"|  "./themes/one_dark.toml"|' "$ALAC"
    # Tmux
    sed -i '' 's|source-file ~/.config/tmux/one_.*.conf|source-file ~/.config/tmux/one_dark.conf|' "$TMUXC"
    # Neovim (normalize indent to 2 spaces; live file may use tab or spaces)
    sed -E -i '' 's/^[[:space:]]*theme = "one[^"]*",*/  theme = "onedark",/' "$NVIMC"
  else
    # Ghostty
    sed -i '' 's/^theme = one_.*$/theme = one_light/' "$GHOSTTYC"
    # Alacritty
    sed -i '' 's|  "./themes/one_.*.toml"|  "./themes/one_light.toml"|' "$ALAC"
    # Tmux
    sed -i '' 's|source-file ~/.config/tmux/one_.*.conf|source-file ~/.config/tmux/one_light.conf|' "$TMUXC"
    # Neovim (normalize indent to 2 spaces; live file may use tab or spaces)
    sed -E -i '' 's/^[[:space:]]*theme = "one[^"]*",*/  theme = "one_light",/' "$NVIMC"
  fi
}

reload() {
  printc "${YELLOW}Reloading...${RESET}"

  # Tmux (safe if no server running)
  if tmux source-file "$TMUXC" 2>/dev/null; then
    printc "${GREEN}  tmux:${RESET} config reloaded"
  else
    printc "${YELLOW}  tmux:${RESET} no server running (will pick up on next attach)"
  fi

  # Terminals
  printc "${GREEN}  alacritty:${RESET} auto-reloads (new or existing windows)"
  printc "${GREEN}  ghostty:${RESET}   press ${CYAN}super+shift+,${RESET} (or Command Palette → Reload Config)"

  # Neovim
  printc "${YELLOW}  nvim:${RESET} restart Neovim or run ${CYAN}:lua require('base46').toggle_theme()${RESET} inside running instances"
  printc "${YELLOW}        (theme_toggle in chadrc keeps the built-in toggle in sync)${RESET}"
}

status() {
  local cur
  cur=$(current)

  printc "${CYAN}=== Theme Status ===${RESET}"
  printc "  Overall (Ghostty primary): ${GREEN}${cur}${RESET}"

  # Alacritty detail
  if [[ -f "$ALAC" ]]; then
    local a
    a=$(grep -v '^#' "$ALAC" | grep -o 'one_[^"]*.toml' | head -1 | sed 's/.toml//; s/_/ /')
    printc "  Alacritty:  ${a:-unknown}"
  else
    printc "  Alacritty: ${RED}config not found${RESET}"
  fi

  # Ghostty detail
  if [[ -f "$GHOSTTYC" ]]; then
    local g
    g=$(grep -v '^#' "$GHOSTTYC" | grep -o 'one_[^ ]*' | head -1 | sed 's/_/ /')
    printc "  Ghostty:   ${g:-unknown}"
  else
    printc "  Ghostty:   ${RED}config not found${RESET}"
  fi

  # Tmux detail
  if [[ -f "$TMUXC" ]]; then
    local t
    t=$(grep 'source-file.*one_' "$TMUXC" | sed -E 's|.*/(one_[^/]+).conf.*|\1|; s/_/ /')
    printc "  Tmux:      ${t:-unknown}"
  else
    printc "  Tmux:      ${RED}config not found${RESET}"
  fi

  # Nvim detail
  if [[ -f "$NVIMC" ]]; then
    local n
    n=$(grep -E '^[[:space:]]*theme =' "$NVIMC" | head -1 | sed -E 's/.*theme = "([^"]+)".*/\1/')
    printc "  Neovim:    ${n:-unknown}"
  else
    printc "  Neovim:    ${RED}chadrc not found${RESET}"
  fi

  # Drift warning (only active lines)
  local a_dark a_light t_dark t_light n_dark n_light
  a_dark=$(grep -v '^#' "$ALAC" 2>/dev/null | grep -c 'one_dark.toml' 2>/dev/null || true)
  a_light=$(grep -v '^#' "$ALAC" 2>/dev/null | grep -c 'one_light.toml' 2>/dev/null || true)
  t_dark=$(grep -E '^\s*source-file' "$TMUXC" | grep -c 'one_dark.conf' 2>/dev/null || true)
  t_light=$(grep -E '^\s*source-file' "$TMUXC" | grep -c 'one_light.conf' 2>/dev/null || true)
  n_dark=$(grep -E '^\s*theme =' "$NVIMC" | grep -c 'onedark' 2>/dev/null || true)
  n_light=$(grep -E '^\s*theme =' "$NVIMC" | grep -c 'one_light' 2>/dev/null || true)

  # Drift check using [ ] (more forgiving with command-sub "0"/"1" strings)
  local drift=0
  if [[ "$cur" == "dark" ]]; then
    [ "${a_light:-0}" -gt 0 ] && drift=1
    [ "${t_light:-0}" -gt 0 ] && drift=1
    [ "${n_light:-0}" -gt 0 ] && drift=1
  elif [[ "$cur" == "light" ]]; then
    [ "${a_dark:-0}" -gt 0 ] && drift=1
    [ "${t_dark:-0}" -gt 0 ] && drift=1
    [ "${n_dark:-0}" -gt 0 ] && drift=1
  fi
  if [ "$drift" -eq 1 ]; then
    printc "${RED}  WARNING: drift detected between apps!${RESET} Run ${CYAN}theme $cur${RESET} to force consistency."
  fi
  echo
}

# --- Main dispatcher ---
main() {
  local cmd="${1:-status}"

  case "$cmd" in
    -h|--help)
      usage
      ;;
    status|"")
      status
      ;;
    dark)
      printc "${CYAN}Switching to DARK...${RESET}"
      apply dark
      reload
      status
      ;;
    light)
      printc "${CYAN}Switching to LIGHT...${RESET}"
      apply light
      reload
      status
      ;;
    auto)
      local target
      target=$(detect_appearance)
      printc "${CYAN}AUTO: macOS reports ${target}${RESET}"
      if [[ "$(current)" == "$target" ]]; then
        printc "${GREEN}Already on ${target}. Nothing to do.${RESET}"
        status
        return
      fi
      apply "$target"
      reload
      status
      ;;
    toggle)
      local cur
      cur=$(current)
      if [[ "$cur" == "dark" ]]; then
        printc "${CYAN}TOGGLE: dark → light${RESET}"
        apply light
      else
        printc "${CYAN}TOGGLE: light → dark${RESET}"
        apply dark
      fi
      reload
      status
      ;;
    *)
      printc "${RED}Unknown command: $cmd${RESET}"
      usage
      exit 1
      ;;
  esac
}

main "$@"
